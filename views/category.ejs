<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Categories</title>
    <link rel="stylesheet" href="/css/category.css">
</head>

<body>
    <div class="tabs">
        <nav>
            <button style="background-color: gray;"><a style="color: black;"
                    href="/api/category/getCategory">Categories</a></button>
            <button style="background-color: gray;"><a style="color: black;"
                    href="/api/product/getProduct">Products</a></button>
        </nav>
    </div>

    <h1>Manage Categories</h1>

    <% if (typeof error !=='undefined' && error) { %>
        <div class="error">
            <%= error %>
        </div>
        <% } %>

            <div class="box">
                <form action="/api/category/addCategory" method="POST">
                    <h2>Add New Category</h2>
                    <input type="text" name="name" required placeholder="Category Name">
                    <button type="submit">Add Category</button>
                </form>
            </div>

            <div class="table-container">
                <table>
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>Category Details (Edit to Update)</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% if (typeof categories !=='undefined' && categories.length> 0) { %>
                            <% categories.forEach(cat=> { %>
                                <tr>
                                    <td width="50">
                                        <%= cat.id %>
                                    </td>
                                    <td>
                                        <form action="/api/category/updateCategory/<%= cat.id %>?_method=PUT"
                                            method="POST" onsubmit="return handleUpdate(this);">
                                            <input type="text" name="name" value="<%= cat.name %>" required>
                                            <button type="submit">Update</button>
                                        </form>
                                    </td>
                                    <td width="100">
                                        <form action="/api/category/deleteCategory/<%= cat.id %>?_method=DELETE"
                                            method="POST">
                                            <button type="submit" class="btn-danger">Delete</button>
                                        </form>
                                    </td>
                                </tr>
                                <% }) %>
                                    <% } else { %>
                                        <tr>
                                            <td colspan="3" style="text-align: center; padding: 20px;">No categories
                                                found.
                                            </td>
                                        </tr>
                                        <% } %>
                    </tbody>
                </table>
            </div>

            <div style="margin-top: 20px; display: flex; justify-content: center; align-items: center; gap: 15px;">
                <% if (typeof currentPage !=='undefined' && typeof totalPages !=='undefined' && totalPages> 1) { %>
                    <% if (currentPage> 1) { %>
                        <a href="?page=<%= currentPage - 1 %>"
                            style="display: inline-block; padding: 8px 16px; background: var(--primary); color: white; border-radius: 6px; text-decoration: none; font-weight: 600; font-size: 14px; transition: background-color 0.15s;">Previous</a>
                        <% } %>

                            <span style="font-size: 14px; font-weight: 600; color: var(--text-dark);">
                                Page <%= currentPage %> of <%= totalPages %>
                            </span>

                            <% if (currentPage < totalPages) { %>
                                <a href="?page=<%= currentPage + 1 %>"
                                    style="display: inline-block; padding: 8px 16px; background: var(--primary); color: white; border-radius: 6px; text-decoration: none; font-weight: 600; font-size: 14px; transition: background-color 0.15s;">Next</a>
                                <% } %>
                                    <% } %>
            </div>
            <script>
                function handleUpdate(form) {
                    const row = form.closest('tr');
                    if (row) {
                        row.style.backgroundColor = '#fef08a';
                        row.style.transition = 'background-color 0.3s';
                    }
                    const btn = form.querySelector('button[type="submit"]');
                    if (btn) {
                        btn.innerHTML = 'Updating...';
                        btn.style.opacity = '0.7';
                        btn.style.pointerEvents = 'none';
                    }
                    return true;
                }
            </script>
</body>

</html>