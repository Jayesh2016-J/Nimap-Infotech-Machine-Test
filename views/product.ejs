<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Products</title>
    <link rel="stylesheet" href="/css/product.css">
</head>

<body>
    <div class="tabs">
        <nav>
            <button style="background-color: gray;"><a style="color: black;"
                    href="/api/category/getCategory">Categories</a></button>
            <button style="background-color: gray;"><a style="color: black;"
                    href="/api/product/getProduct">Products</a></button>
        </nav>
    </div>

    <h1>Manage Products</h1>

    <% if (typeof error !=='undefined' && error) { %>
        <div class="error">
            <%= error %>
        </div>
        <% } %>

            <div class="box">
                <form action="/api/product/addProduct" method="POST">
                    <h2>Add New Product</h2>
                    <input type="text" name="name" required placeholder="Product Name">
                    <input type="number" step="0.01" name="price" required placeholder="Price">
                    <select name="categoryId" required>
                        <option value="">Select Category</option>
                        <% if (typeof categories !=='undefined' && categories.length> 0) { %>
                            <% categories.forEach(cat=> { %>
                                <option value="<%= cat.id %>">
                                    <%= cat.name %>
                                </option>
                                <% }) %>
                                    <% } %>
                    </select>
                    <button type="submit">Add Product</button>
                </form>
            </div>

            <div class="table-container">
                <table>
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>Product Details (Edit to Update)</th>
                            <th>Current Category</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% if (typeof products !=='undefined' && products.length> 0) { %>
                            <% products.forEach(prod=> { %>
                                <tr>
                                    <td width="50">
                                        <%= prod.id %>
                                    </td>
                                    <td>
                                        <form action="/api/product/updateProduct/<%= prod.id %>?_method=PUT"
                                            method="POST" style="display:flex; align-items:center;"
                                            onsubmit="return handleUpdate(this);">
                                            <input type="text" name="name" value="<%= prod.name %>" required
                                                style="width: 140px; margin-bottom:0;">
                                            <input type="number" step="0.01" name="price" value="<%= prod.price %>"
                                                required style="width: 80px; margin-bottom:0;">
                                            <select name="categoryId" required style="margin-bottom:0;">
                                                <% categories.forEach(cat=> { %>
                                                    <option value="<%= cat.id %>" <%=prod.categoryId===cat.id
                                                        ? 'selected' : '' %>>
                                                        <%= cat.name %>
                                                    </option>
                                                    <% }) %>
                                            </select>
                                            <button type="submit" style="margin-left:5px;">Update</button>
                                        </form>
                                    </td>
                                    <td>
                                        <%= prod.category ? prod.category.name : 'Unknown' %>
                                    </td>
                                    <td width="100">
                                        <form action="/api/product/deleteProduct/<%= prod.id %>?_method=DELETE"
                                            method="POST">
                                            <button type="submit" class="btn-danger">Delete</button>
                                        </form>
                                    </td>
                                </tr>
                                <% }) %>
                                    <% } else { %>
                                        <tr>
                                            <td colspan="4" style="text-align: center; padding: 20px;">No products
                                                found.
                                            </td>
                                        </tr>
                                        <% } %>
                    </tbody>
                </table>
            </div>

            <div style="margin-top: 20px; display: flex; justify-content: center; align-items: center; gap: 15px;">
                <% if (typeof currentPage !=='undefined' && typeof totalPages !=='undefined' && totalPages> 1) { %>
                    <% if (currentPage> 1) { %>
                        <a href="?page=<%= currentPage - 1 %>"
                            style="display: inline-block; padding: 8px 16px; background: var(--primary); color: white; border-radius: 6px; text-decoration: none; font-weight: 600; font-size: 14px; transition: background-color 0.15s;">Previous</a>
                        <% } %>

                            <span style="font-size: 14px; font-weight: 600; color: var(--text-dark);">
                                Page <%= currentPage %> of <%= totalPages %>
                            </span>

                            <% if (currentPage < totalPages) { %>
                                <a href="?page=<%= currentPage + 1 %>"
                                    style="display: inline-block; padding: 8px 16px; background: var(--primary); color: white; border-radius: 6px; text-decoration: none; font-weight: 600; font-size: 14px; transition: background-color 0.15s;">Next</a>
                                <% } %>
                                    <% } %>
            </div>
            <script>
                function handleUpdate(form) {
                    const row = form.closest('tr');
                    if (row) {
                        row.style.backgroundColor = '#fef08a';
                        row.style.transition = 'background-color 0.3s';
                    }
                    const btn = form.querySelector('button[type="submit"]');
                    if (btn) {
                        btn.innerHTML = 'Updating...';
                        btn.style.opacity = '0.7';
                        btn.style.pointerEvents = 'none';
                    }
                    return true;
                }
            </script>
</body>

</html>